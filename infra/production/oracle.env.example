# Configuración no secreta para `docker compose --env-file`.
# Copiar fuera del release a /etc/opn-oracle/oracle.env con owner/permisos aprobados.
ORACLE_RELEASE=replace-with-immutable-release-id
ORACLE_APP_VERSION=0.1.0
ORACLE_GRAPH_SENDER_MAILBOX=oracle@example.invalid
SIGNAL_AVANZA_ENABLED=false
SIGNAL_AVANZA_MODE=mock
SIGNAL_AVANZA_CONTRACT_CONFIRMED=false
SIGNAL_AVANZA_ALLOWED_HOSTS=signal.opnconsultoria.com
SIGNAL_AVANZA_BASE_URL=https://signal.opnconsultoria.com/api/v1/oracle
SIGNAL_AVANZA_API_VERSION=2026-07-01
ORACLE_AI_ENABLED=false
ORACLE_AI_MODE=disabled
ORACLE_AI_DEFAULT_MODEL=mock-oracle-v1
ORACLE_CELERY_TIMEZONE=Europe/Madrid
ORACLE_NIGHTLY_SUMMARIES_ENABLED=true
ORACLE_NIGHTLY_SUMMARIES_HOUR=3
ORACLE_NIGHTLY_SUMMARIES_MINUTE=15
ORACLE_SIGNAL_AI_BASE_URL=https://signal.opnconsultoria.com
ORACLE_SIGNAL_AI_ALLOWED_HOSTS=signal.opnconsultoria.com
ORACLE_SIGNAL_AI_TIMEOUT_SECONDS=210

# El directorio contiene valores secretos, nunca se versiona ni se imprime.
ORACLE_SECRETS_DIR=/etc/opn-oracle/secrets
