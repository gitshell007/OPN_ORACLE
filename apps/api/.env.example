# Local development only. Copy to .env and rotate every production value elsewhere.
APP_ENV=development
FLASK_DEBUG=true
SECRET_KEY=local-development-only-change-me
DATABASE_URL=postgresql+psycopg://oracle_app:change-this-local-password@127.0.0.1:5432/opn_oracle
DATABASE_MIGRATION_URL=postgresql+psycopg://oracle_migrator:change-this-separate-password@127.0.0.1:5432/opn_oracle
RLS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_REDIS_URL=redis://127.0.0.1:6379/1
RATELIMIT_STORAGE_URL=redis://127.0.0.1:6379/2
SESSION_COOKIE_NAME=opn_oracle_session
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12
SENSITIVE_REAUTH_MINUTES=10
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_BYTES=1024
AUTH_MAX_FAILURES=5
AUTH_LOCK_SECONDS=300
INVITATION_TTL_HOURS=72
PASSWORD_RESET_TTL_MINUTES=30
REVOKE_OTHER_SESSIONS_ON_PASSWORD_CHANGE=true
MAIL_BACKEND=capture
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=oracle@localhost
# Microsoft Graph application permissions (alternative to SMTP).
# GRAPH_CLIENT_SECRET_FILE is recommended outside development.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_MAILBOX=
GRAPH_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO
LOG_FORMAT=console
METRICS_ENABLED=false
METRICS_TOKEN=
HSTS_ENABLED=false
TRUSTED_PROXY_COUNT=0
FRONTEND_ORIGIN=http://localhost:3000
OPENAPI_ENABLED=true
APP_VERSION=0.1.0
RELEASE=development
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_TIMEOUT_SECONDS=1.0
DEPENDENCY_TIMEOUT_SECONDS=1.0
CELERY_BROKER_URL=redis://127.0.0.1:6379/3
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/4
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
CELERY_ACKS_LATE=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_SOFT_TIME_LIMIT=270
CELERY_TASK_TIME_LIMIT=300
CELERY_RESULT_EXPIRES=3600
CELERY_DEFAULT_QUEUE=default
# Closed by default. Use AI_MODE=signal to call Signal /api/v1/ai/run; never call
# Ollama/OpenRouter directly from Oracle for dossier_situation_summary.
AI_ENABLED=false
AI_MODE=disabled
AI_DEFAULT_MODEL=mock-oracle-v1
AI_MOCK_SEED=opn-oracle-local
SIGNAL_AI_BASE_URL=
SIGNAL_AI_ALLOWED_HOSTS=
SIGNAL_AI_API_KEY=
SIGNAL_AI_TIMEOUT_SECONDS=210
# Documents are enabled locally with private filesystem storage. Production must
# explicitly enable the module, S3 and ClamAV; never copy these local defaults.
DOCUMENTS_ENABLED=true
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_LOCAL_ROOT=.oracle-storage
DOCUMENT_MAX_BYTES=26214400
DOCUMENT_TENANT_QUOTA_BYTES=1073741824
DOCUMENT_SCANNER_MODE=noop
DOCUMENT_CLAMAV_HOST=
DOCUMENT_CLAMAV_PORT=3310
DOCUMENT_CLAMAV_TIMEOUT_SECONDS=15
DOCUMENT_S3_ENDPOINT_URL=
DOCUMENT_S3_REGION=
DOCUMENT_S3_BUCKET=
DOCUMENT_S3_ACCESS_KEY_ID=
DOCUMENT_S3_SECRET_ACCESS_KEY=
DOCUMENT_S3_ALLOWED_HOSTS=
BACKUP_STORAGE_PATH=/var/backups/opn-oracle
BACKUP_RETENTION_DAYS=30
